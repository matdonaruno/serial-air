{
  "expo": {
    "name": "Serial Air",
    "slug": "serial-air",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "serial-air",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.serialair.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Serial Air uses your local network to discover and connect to microcontrollers for serial monitoring.",
        "NSBluetoothAlwaysUsageDescription": "Serial Air uses Bluetooth to discover and connect to nearby ESP32 microcontrollers.",
        "NSBonjourServices": [
          "_serial-air._tcp.",
          "_serial-air._tcp.local.",
          "_serial-air._tcp.local"
        ]
      }
    },
    "android": {
      "package": "com.serialair.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "permissions": [
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-updates",
        {
          "username": "serial-air"
        }
      ],
      "expo-secure-store",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3cd1e3fa-5063-4118-8dbe-c17116f7e294"
      }
    },
    "owner": "masashiumetani"
  }
}
